# ── Required ──────────────────────────────────────────────────────────────────
# A long random string used to sign session cookies.
# Generate one with: openssl rand -base64 48
SESSION_SECRET=your-long-random-secret-here

# ── Database (choose ONE option) ───────────────────────────────────────────────

# Option A – direct PostgreSQL connection string (Supabase, Neon, Railway, etc.)
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# Option B – Supabase discrete variables (used automatically when all three are set)
# SUPABASE_DB_PASSWORD=your-supabase-db-password
# SUPABASE_PROJECT_REF=your-project-ref
# SUPABASE_DB_HOST=aws-0-ap-south-1.pooler.supabase.com
# SUPABASE_DB_PORT=6543   # optional, defaults to 6543
