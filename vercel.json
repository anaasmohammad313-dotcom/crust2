{
  "buildCommand": "pnpm --filter @workspace/api-server run build && BASE_PATH=/ pnpm --filter @workspace/pos run build",
  "outputDirectory": "artifacts/pos/dist/public",
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/index" }
  ],
  "headers": [
    {
      "source": "/api/:path*",
      "headers": [
        { "key": "Cache-Control", "value": "no-store" }
      ]
    }
  ]
}
